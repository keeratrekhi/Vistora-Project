{
  "redirects": [
    {
      "source": "/gallery/:id",
      "destination": "/gallery/client/:id",
      "statusCode": 302
    }
  ],
  "rewrites": [
    {
      "source": "/gallery/:id",
      "destination": "/api/gallery/:id"
    },
    {
      "source": "/gallery/client/:id",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}