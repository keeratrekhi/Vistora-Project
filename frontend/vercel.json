{
  "rewrites": [
    {
      "source": "/gallery/:id",
      "has": [
        { "type": "header", "key": "user-agent", "value": "facebookexternalhit" },
        { "type": "header", "key": "user-agent", "value": "Twitterbot" },
        { "type": "header", "key": "user-agent", "value": "WhatsApp" },
        { "type": "header", "key": "user-agent", "value": "LinkedInBot" }
      ],
      "destination": "/api/gallery/:id"
    },
    {
      "source": "/gallery/:id",
      "destination": "/gallery/client/:id",
      "statusCode": 302
    },
    {
      "source": "/gallery/client/:id",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
